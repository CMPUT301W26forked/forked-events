<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_grey"
    android:padding="24dp">

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Event Lottery"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="48dp"/>

    <!-- Toggle: Login / Sign-up -->
    <LinearLayout
        android:id="@+id/toggleContainer"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_toggle_container"
        android:orientation="horizontal"
        android:padding="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tabLogin"
            android:layout_width="120dp"
            android:layout_height="match_parent"
            android:text="Login"
            android:textSize="14sp"
            android:gravity="center"
            android:textColor="@color/black"
            android:background="@drawable/bg_tab_selected" />

        <TextView
            android:id="@+id/tabSignup"
            android:layout_width="120dp"
            android:layout_height="match_parent"
            android:text="Sign-up"
            android:textSize="14sp"
            android:gravity="center"
            android:textColor="@color/black"
            android:background="@android:color/transparent" />
    </LinearLayout>

    <!-- Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/formCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/white"
        app:layout_constraintTop_toBottomOf="@id/toggleContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Name field (Sign-up only) -->
            <TextView
                android:id="@+id/labelName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Name"
                android:textSize="14sp"
                android:textColor="@color/black"
                android:visibility="gone" />

            <EditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"
                android:hint="Value"
                android:background="@drawable/bg_toggle_container"
                android:paddingHorizontal="12dp"
                android:inputType="textPersonName"
                android:visibility="gone" />

            <!-- Email -->
            <TextView
                android:id="@+id/labelEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email"
                android:textSize="14sp"
                android:textColor="@color/black" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"
                android:hint="Value"
                android:background="@drawable/bg_toggle_container"
                android:paddingHorizontal="12dp"
                android:inputType="textEmailAddress" />

            <!-- Password -->
            <TextView
                android:id="@+id/labelPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Password"
                android:textSize="14sp"
                android:textColor="@color/black" />

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"
                android:hint="Value"
                android:background="@drawable/bg_toggle_container"
                android:paddingHorizontal="12dp"
                android:inputType="textPassword" />

            <!-- Primary Action Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPrimary"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Sign In"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textAllCaps="false"
                android:backgroundTint="#1A1A1A"
                app:cornerRadius="12dp" />

            <!-- Forgot Password (Login only) -->
            <TextView
                android:id="@+id/tvForgotPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Forgot password?"
                android:textSize="13sp"
                android:textColor="@color/black" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Continue as Guest -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGuest"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:text="Continue as guest"
        android:textColor="@color/black"
        android:textSize="14sp"
        android:textAllCaps="false"
        app:backgroundTint="@color/bg_grey"
        app:cornerRadius="12dp"
        app:strokeColor="@color/bg_grey"
        app:layout_constraintTop_toBottomOf="@id/formCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Device identified -->
    <TextView
        android:id="@+id/tvDeviceInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Device identified automatically"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        app:layout_constraintTop_toBottomOf="@id/btnGuest"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>